{
  "name": "blockchain-voting-system",
  "version": "1.0.0",
  "description": "Blockchain-based voting system with Hardhat + React/Vite",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy": "hardhat run scripts/deploy.js --network localhost",
    "initialize": "hardhat run scripts/initialize.js --network localhost",
    "deploy:fresh": "npm run compile && npm run deploy && npm run initialize",
    "frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.0"
  }
}